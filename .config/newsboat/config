auto-reload yes
browser "$BROWSER %u"

# Keybindings

bind-key j down
bind-key k up
bind-key l open 
bind-key h quit 

# Macros

macro y set browser "mpv %u" ; open-in-browser ; set browser "elinks %u"
macro , set browser "com.brave.Browser %u" ; open-in-browser

highlight feedlist "---.*---" cyan default bold
highlight feedlist ".*0/0.." default default invis
