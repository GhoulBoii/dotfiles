#!/bin/env sh
xrandr --output HDMI-0 --mode 1440x900 --primary --output LVDS-1-1 --mode 1366x768 --right-of HDMI-0 --output VGA-0 --off
xinput --set-prop "  CB Gaming" 'libinput Accel Profile Enabled' 0, 1 
xinput --set-prop "SynPS/2 Synaptics TouchPad" 369 0 
xset -dpms

#################
#   Autostart   #
#################

set-wallpaper.sh
easyeffects --gapplication-service &
unclutter &
picom -b
xbindkeys -f ~/.config/xbindkeys/config
mpris-proxy &

###################
#   Xorg Server   #
###################

session=dwm
case $session in
    dwm               ) dwm-restart.sh;;
    awesome           ) exec dbus-launch awesome;;
    *                 ) exec dbus-launch $1;;
esac
