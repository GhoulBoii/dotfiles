# Increase volume
"pactl set-sink-volume @DEFAULT_SINK@ +10%; kill -59 $(pidof dwmblocks)"
   XF86AudioRaiseVolume

# Decrease volume
"pactl set-sink-volume @DEFAULT_SINK@ -10%; kill -59 $(pidof dwmblocks)"
   XF86AudioLowerVolume

# Mute volume
"pactl set-sink-mute @DEFAULT_SINK@ toggle; kill -59 $(pidof dwmblocks)"
   XF86AudioMute

# Mute microphone
"pactl set-source-mute @DEFAULT_SOURCE@ toggle"
   XF86AudioMicMute

# Play/Pause Audio
"playerctl play-pause"
   XF86AudioPlay

# Flameshot for screenshots
"org.flameshot.Flameshot gui"
    Print

# Audio Next
"playerctl next"
  XF86AudioNext

# Audio Previous
"playerctl previous"
  XF86AudioPrev

# Btop
"wezterm start -- btop"
  Control+Shift+Escape
